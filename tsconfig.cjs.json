{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM"],
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist/cjs",
    "declarationDir": "./dist/cjs/types",
    "rootDir": "./src",
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "node_modules"]
}
