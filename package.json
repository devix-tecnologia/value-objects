{
  "name": "@devix-tecnologia/value-objects",
  "version": "2.6.0",
  "description": "Coleção de objetos de valores para implementação em sistemas.",
  "main": "./dist/cjs/index.js",
  "type": "module",
  "types": "./dist/esm/types/index.d.ts",
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devix-tecnologia/value-objects.git"
  },
  "private": false,
  "keywords": [
    "value-objects",
    "devix",
    "devix-tecnologia"
  ],
  "scripts": {
    "test": "vitest run",
    "clean": "rm -rf ./dist",
    "build": "pnpm clean && pnpm build:esm && pnpm build:cjs",
    "build:esm": "tsc -p ./tsconfig.esm.json && mv dist/esm/index.js dist/esm/index.mjs",
    "build:cjs": "tsc -p ./tsconfig.cjs.json",
    "postbuild": "node ./scripts/prepare-package-json",
    "prepack": "pnpm build",
    "semantic-release": "semantic-release",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "lint": "eslint --fix --ext .ts,.tsx --no-error-on-unmatched-pattern --max-warnings=0 --config eslint.config.js src/"
  },
  "author": "Devix Tecnologia Ltda",
  "contributors": [
    {
      "name": "Roberto Seba",
      "github": "https://github.com/robertoseba",
      "linkedin": "https://www.linkedin.com/in/robertoseba"
    },
    {
      "name": "Sidarta Veloso",
      "github": "https://github.com/sidartaveloso",
      "linkedin": "https://www.linkedin.com/in/sidartaveloso"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/ui": "^4.1.9",
    "assert": "^2.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "taskin": "^3.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/types/index.d.ts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
